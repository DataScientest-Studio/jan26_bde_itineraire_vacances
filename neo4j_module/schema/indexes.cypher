///////////////////////////////////////////////////////////////////////////
// indexes.cypher
// Index pour optimiser les performances des requêtes Neo4j
///////////////////////////////////////////////////////////////////////////


///////////////////////////////////////////////////////////////////////////
// 1. Index géographiques sur les POI
///////////////////////////////////////////////////////////////////////////

CREATE INDEX poi_location_index IF NOT EXISTS
FOR (p:POI) ON (p.lat, p.lon);


///////////////////////////////////////////////////////////////////////////
// 2. Index sur les villes
///////////////////////////////////////////////////////////////////////////

CREATE INDEX city_name_index IF NOT EXISTS
FOR (c:City) ON (c.name);


///////////////////////////////////////////////////////////////////////////
// 3. Index sur les thèmes
///////////////////////////////////////////////////////////////////////////

CREATE INDEX theme_name_index IF NOT EXISTS
FOR (t:Theme) ON (t.name);
