///////////////////////////////////////////////////////////////////////////
// constraints.cypher
// Contraintes d’existence pour le graphe Neo4j
///////////////////////////////////////////////////////////////////////////


///////////////////////////////////////////////////////////////////////////
// 2. Contraintes d’existence sur les relations
///////////////////////////////////////////////////////////////////////////

// Unicité des POI
CREATE CONSTRAINT poi_id_unique IF NOT EXISTS
FOR (p:POI) REQUIRE p.poi_id IS UNIQUE;

// Unicité des villes
CREATE CONSTRAINT city_id_unique IF NOT EXISTS
FOR (c:City) REQUIRE c.city_id IS UNIQUE;

// Unicité des thèmes
CREATE CONSTRAINT theme_name_unique IF NOT EXISTS
FOR (t:Theme) REQUIRE t.name IS UNIQUE;
