# ============================
# 🔐 BASE DE DONNÉES POSTGRES
# ============================
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=dbname
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}


# ============================
# 🍃 MONGODB
# ============================
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DB=defaultdb

MONGO_URL=mongodb://${MONGO_HOST}:${MONGO_PORT}


# ============================
# 🕸️ NEO4J
# ============================
NEO4J_HOST=neo4j
NEO4J_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_URL=bolt://${NEO4J_HOST}:${NEO4J_PORT}


# ============================
# 🚀 FASTAPI
# ============================
API_ENV=development
API_PORT=8000


# ============================
# 📊 JUPYTER
# ============================
JUPYTER_TOKEN=devtoken


# ============================
# 🛠️ ETL / ML
# ============================
DATA_DIR=/data
MODEL_DIR=/ml/models/saved
